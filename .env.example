# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Database (Prisma) ---
# Supabase transaction pooler (port 6543) — used by the app at runtime on serverless.
DATABASE_URL=
# Supabase direct connection (port 5432) — used by `prisma migrate`.
DIRECT_URL=

# --- Supabase (Auth + Realtime only; all DB access goes through Prisma) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional ---
# PEM-encoded CA certificate for verifying the Postgres TLS connection.
# Only needed where the platform does not trust Supabase's CA out of the box.
# SUPABASE_CA_CERT=
